RewriteEngine On

# Archivos reales en la raíz → servirlos directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Raíz → public/index.php
RewriteRule ^$ public/index.php [QSA,L]

# El resto → public/ (solo si no es archivo ni directorio real)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/$1 [QSA,L]
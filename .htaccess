# Redirigir todo al public/ excepto archivos existentes en la raíz
RewriteEngine On

# Permitir acceso directo a archivos reales en la raíz del proyecto (ej: .env no debería estar aquí)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Redirigir raíz → public/index.php (para inyección de API URL)
RewriteRule ^$ public/index.php [QSA,L]

# Redirigir todo lo demás → public/ manteniendo la ruta
RewriteRule ^(.*)$ public/$1 [QSA,L]

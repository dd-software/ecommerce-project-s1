DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=uct_ecommerce
DB_USER=ecommerce_app
DB_PASS=app_password_here
JWT_SECRET=change_this_to_a_random_32_char_string
JWT_EXPIRY=7200
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp_password_here
SMTP_FROM=noreply@example.com

# MercadoPago Access Token. Vacío o "change_..." => el pago corre simulado (dev).
# Producción: pegá el Access Token de tu cuenta. APP_URL debe ser tu dominio HTTPS público
# (MercadoPago llama al webhook /api/pagos/webhook desde sus servidores).
MP_ACCESS_TOKEN=change_me_to_your_mercadopago_access_token

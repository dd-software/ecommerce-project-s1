Options -MultiViews -Indexes
RewriteEngine On

# IMPORTANTE: RewriteBase debe coincidir con la ruta del subdirectorio
# Si el proyecto está en /~mvaldebenito2025/public/, usar ese path
RewriteBase /~mvaldebenito2025/public/

<IfModule headers_module>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # CSP ampliado para permitir Bootstrap CDN y Google Fonts
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://cdn.jsdelivr.net https://fonts.gstatic.com; connect-src 'self' https://teclab.uct.cl"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Authorization, Content-Type, X-Request-ID, X-Session-Id"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

<IfModule !headers_module>
    # Si mod_headers no está disponible, se omite (seguridad básica igual funciona)
</IfModule>

# Manejo de preflight OPTIONS
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=200,L]

# -------------------------------------------------------
# Servir archivos HTML estáticos directamente (sin pasar por index.php)
# Esto permite que admin.html, producto.html, etc. se sirvan como estáticos
# -------------------------------------------------------
RewriteRule ^(index|admin|producto|pedido-confirmado|catalogo|carrito|checkout|login)\.html$ - [L,NC]

# Permitir acceso directo a archivos y directorios existentes (assets, imágenes, css, js)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Enrutar el resto al front controller (API)
RewriteRule ^ index.php [QSA,L]

